# Telegram Bot Token - get it from @BotFather
BOT_TOKEN=your_telegram_bot_token

# Groq API Key - free tier - https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# Gemini API Key - free tier - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Comma separated Telegram user IDs that are always treated as bot admins
ADMIN_IDS=123456789,987654321

# Comma separated keywords (no spaces around commas) that trigger the AI
# when a message starts with one of them
TRIGGER_KEYWORDS=هوش,bot,ربات